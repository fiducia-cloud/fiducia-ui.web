#!/usr/bin/env bash
# Entry into the Nix dev shell: runs `nix develop ./.nix`, optionally executing a
# passed command inside it (e.g. `./shell npm run build`).
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

if [[ $# -gt 0 ]]; then
  exec nix develop "$repo_root/.nix" --command "$@"
fi

exec nix develop "$repo_root/.nix"
